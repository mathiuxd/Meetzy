@page "/comunidades"

<div class="container-fluid">
    <h2 style="color: var(--neon-cyan);">EXPLORA LAS COMUNIDADES</h2>

    <!-- BOTÓN CREAR -->
    <div style="margin-bottom: 20px;">
        <button class="btn-neon">+ CREAR COMUNIDAD</button>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px;">

        <div class="meetzy-card">
            <h3>Tech & Blockchain 🧑🏻‍💻</h3>
            <p>Programación, IA y desarrollo.</p>

            
            <div style="margin-top: 10px;">
                <button class="btn-neon">EDITAR</button>
                <button class="btn-neon" style="border-color:red; color:red;">ELIMINAR</button>
            </div>

            <NavLink href="/eventos/tech" class="btn-neon" style="margin-top:10px;">
                VER PARCHES
            </NavLink>
        </div>

        <div class="meetzy-card">
            <h3>Social & Rumbas 🕺🏻</h3>
            <p>Fiesta y vida nocturna.</p>

            <div>
                <button class="btn-neon">EDITAR</button>
                <button class="btn-neon" style="border-color:red; color:red;">ELIMINAR</button>
            </div>

            <NavLink href="/eventos/social" class="btn-neon">
                VER PARCHES
            </NavLink>
        </div>

    </div>
</div>
