@page "/eventos/{ComunidadNombre}"

<div class="container-fluid">
    <NavLink href="/comunidades" style="color: var(--text-muted); text-decoration: none; font-size: 0.8rem;">
        ← VOLVER A COMUNIDADES
    </NavLink>

    <h2 style="color: var(--neon-pink); text-shadow: 0 0 10px var(--neon-pink); margin-top: 10px;">
        EVENTOS EN @ComunidadNombre.ToUpper()
    </h2>

    @foreach (var evento in eventosSimulados)
    {
        <div class="meetzy-card" style="border-left: 4px solid var(--neon-cyan);">
            <div style="display: flex; justify-content: space-between;">
                <h3 style="color: white;">@evento.Titulo</h3>
                <span style="color: var(--neon-cyan);">@evento.Fecha</span>
            </div>
            
            <p style="color: var(--text-muted); margin: 15px 0;">
                @evento.Descripcion
            </p>

            <!-- Botones de Acción -->
            <div style="display: flex; gap: 10px; margin-bottom: 20px;">
                <button class="btn-neon" style="font-size: 0.8rem;">Confirmar Asistencia</button>
                <button class="btn-neon" style="border-color: #ffcc00; color: #ffcc00; font-size: 0.8rem;">Me interesa</button>
                <button class="btn-neon" style="border-color: var(--neon-pink); color: var(--neon-pink); font-size: 0.8rem;">Cancelar</button>
            </div>

            <!-- Sección de Comentarios (Visual) -->
            <div style="background: rgba(255,255,255,0.05); padding: 15px; border-radius: 8px;">
                <h5 style="font-size: 0.9rem; color: var(--neon-cyan);">Comentarios del parche:</h5>
                <p style="font-size: 0.8rem; color: #ccc;"><strong>@@UsuarioAnonimo:</strong> [Texto: ¿A qué horas termina el evento?]</p>
                <input type="text" placeholder="Escribe un comentario..."
                       style="background: transparent; border: 1px solid #444; color: white; width: 100%; padding: 5px; font-size: 0.8rem;" />
            </div>
        </div>
    }
</div>

