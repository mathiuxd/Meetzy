@model Meetzy.Application.UseCases.Users.Commands.CreateUser.CreateUserRequest

@{
    ViewData["Title"] = "Registrarse";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow">
            <div class="card-body p-4">
                <h3 class="card-title text-center mb-4">Crear Cuenta</h3>
                <form asp-action="Register" method="post">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Nombre completo</label>
                        <input asp-for="Name" class="form-control" placeholder="Tu nombre" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">Correo electrónico</label>
                        <input asp-for="Email" class="form-control" placeholder="correo@ejemplo.com" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">Contraseña</label>
                        <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" />
                    </div>
                    <input type="hidden" name="RoleId" value="8B781052-5A89-4C48-834B-61835EA673BC" />
                    <button type="submit" class="btn btn-success w-100">Registrarse</button>
                </form>
                <hr />
                <p class="text-center mb-0">¿Ya tienes cuenta? <a href="/Account/Login">Inicia sesión</a></p>
            </div>
        </div>
    </div>
</div>