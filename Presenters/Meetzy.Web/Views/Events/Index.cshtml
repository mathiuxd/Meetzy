@model IEnumerable<Meetzy.Application.UseCases.Events.Queries.GetAllEvents.GetAllEventsResponse>
@{
    ViewData["Title"] = "Events";
}

<h2>Events</h2>
<a asp-action="Create" class="btn btn-primary mb-3">Create Event</a>

<table class="table">
    <thead>
        <tr>
            <th>Title</th>
            <th>City</th>
            <th>Date</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var ev in Model)
        {
            <tr>
                <td>@ev.Title</td>
                <td>@ev.City</td>
                <td>@ev.DateTime.ToString("MM/dd/yyyy HH:mm")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@ev.EventId" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@ev.EventId" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
